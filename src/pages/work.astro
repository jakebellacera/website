---
import { Image } from "astro:assets";
import { getCollection, render } from "astro:content";
import Layout from "../layouts/Layout.astro";
import Prose from "../ui/Prose.astro";

const workEntries = await getCollection("work");
const companies = await getCollection("company");

const companyMap = new Map(companies.map((c) => [c.id, c]));

// Sort by startDate descending (newest first)
const sorted = workEntries.sort(
  (a, b) => b.data.startDate.getTime() - a.data.startDate.getTime(),
);

// Group consecutive entries by company
type Group = { companyId: string; entries: typeof sorted };
const groups: Group[] = [];

for (const entry of sorted) {
  const companyId = entry.data.company.id;
  const lastGroup = groups[groups.length - 1];
  if (lastGroup && lastGroup.companyId === companyId) {
    lastGroup.entries.push(entry);
  } else {
    groups.push({ companyId, entries: [entry] });
  }
}

// Pre-render all markdown content
const rendered = new Map<string, Awaited<ReturnType<typeof render>>>();
for (const entry of workEntries) {
  rendered.set(entry.id, await render(entry));
}

function formatDate(date: Date): string {
  return date.toLocaleDateString("en-US", { month: "long", year: "numeric" });
}

function formatDuration(start: Date, end: Date): string {
  let months =
    (end.getFullYear() - start.getFullYear()) * 12 +
    (end.getMonth() - start.getMonth());
  const years = Math.floor(months / 12);
  months = months % 12;
  const parts: string[] = [];
  if (years > 0) parts.push(`${years} yr${years > 1 ? "s" : ""}`);
  if (months > 0) parts.push(`${months} mo${months > 1 ? "s" : ""}`);
  return parts.join(", ") || "< 1 mo";
}
---

<Layout title="Work">
  <Prose>
    <h1>Work History</h1>
  </Prose>
  <div class="flex flex-col gap-12 pt-12">
    {groups.map((group) => {
      const company = companyMap.get(group.companyId)!;
      return (
        <section>
          <div class="flex items-center gap-3 mb-6">
            <Image
              src={company.data.logo}
              alt={`${company.data.name} logo`}
              class:list={["h-8 w-auto", { "dark:hidden": company.data.logoDark }]}
            />
            {company.data.logoDark && (
              <Image
                src={company.data.logoDark}
                alt={`${company.data.name} logo`}
                class="h-8 w-auto hidden dark:block"
              />
            )}
            <div>
              <h2 class="text-xl font-bold">{company.data.name}</h2>
              <p class="text-sm text-neutral-500 dark:text-neutral-400">{company.data.location}</p>
            </div>
          </div>
          <div class="flex flex-col gap-8 border-l border-neutral-200 dark:border-neutral-700 ml-4 pl-6">
            {group.entries.map((entry, i) => {
              const { Content } = rendered.get(entry.id)!;
              return (
                <div class="relative">
                  {group.entries.length > 1 && i > 0 && (
                    <div class="absolute -left-7.75 top-1.5 w-3 h-3 rounded-full border border-neutral-300 bg-white dark:border-neutral-600 dark:bg-neutral-950 shadow-[0_-4px_0_white] dark:shadow-[0_-4px_0_var(--color-neutral-950)]" />
                  )}
                  <h3 class="text-lg font-semibold">{entry.data.title}</h3>
                  <p class="text-sm text-neutral-500 dark:text-neutral-400 mb-3">
                    {formatDate(entry.data.startDate)} &ndash; {entry.data.endDate ? formatDate(entry.data.endDate) : "Present"} &middot; {formatDuration(entry.data.startDate, entry.data.endDate ?? new Date())}
                  </p>
                  <Prose>
                    <Content />
                  </Prose>
                  <div class="flex flex-wrap gap-2 mt-3">
                    {entry.data.skills.map((skill: string) => (
                      <span class="inline-block px-2.5 py-0.5 text-xs font-medium rounded-full bg-neutral-100 text-neutral-600 dark:bg-neutral-800 dark:text-neutral-300">
                        {skill}
                      </span>
                    ))}
                  </div>
                </div>
              );
            })}
          </div>
        </section>
      );
    })}
  </div>
</Layout>
