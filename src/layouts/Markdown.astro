---
import Layout from "./Layout.astro";

interface Props {
  frontmatter: {
    title: string;
    description?: string;
  };
}

const { title, description } = Astro.props.frontmatter;
---

<Layout title={title} description={description}>
	<main class="prose dark:prose-invert mx-auto max-w-xl px-6 py-12 sm:py-20">
		<slot />
	</main>
</Layout>
